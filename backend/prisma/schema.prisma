generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Shop {
  id             Int      @id @default(autoincrement())
  name           String
  type           String
  openingHours   Json
  latitude       Float
  longitude      Float
  address        String
  neighbourhood  String
  city           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  visitedBy VisitedShop[]
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  passwordHash String
  name         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  visitedShops VisitedShop[]
  brands       UserBrand[]
}

model UserBrand {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String   @db.VarChar(200)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model VisitedShop {
  id              Int       @id @default(autoincrement())
  userId          Int
  shopId          Int
  visitedAt       DateTime  @default(now())
  rating          Float?    // personal ranking 0–10
  ratingUpdatedAt DateTime? // when rating was last set/updated (for activity feed)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  spotteds Spotted[]

  @@unique([userId, shopId])
}

model Spotted {
  id               Int      @id @default(autoincrement())
  visitedShopId    Int
  imageUrl         String?
  brand            String?
  clothingCategory String?
  colour           String?
  createdAt        DateTime @default(now())

  visitedShop VisitedShop @relation(fields: [visitedShopId], references: [id], onDelete: Cascade)
}

